      <property name="styleSheet">
       <string notr="true">
/* Sidebar nền */
QFrame#sidebar {
    background-color: #1A2A4A;
    border: none;
    border-right: 2px solid #C9A84C;
}
/* Label tiêu đề */
QLabel#lbl_app_title {
    background-color: #12213A;
    color: #C9A84C;
    font-size: 15px;
    font-weight: bold;
    padding: 18px 12px;
    border-bottom: 2px solid #C9A84C;
    border-right: none;
}
/* Tất cả nút nav */
QFrame#sidebar QPushButton {
    background-color: transparent;
    color: #B8C4D8;
    font-size: 13px;
    font-weight: 500;
    text-align: left;
    padding: 12px 18px;
    border: none;
    border-left: 3px solid transparent;
    border-radius: 0px;
}
QFrame#sidebar QPushButton:hover {
    background-color: #243558;
    color: #FFFFFF;
    border-left: 3px solid #C9A84C;
}
/* Trạng thái active — set từ code bằng setProperty */
QFrame#sidebar QPushButton[active=true] {
    background-color: #2C4070;
    color: #FFFFFF;
    border-left: 3px solid #C9A84C;
    font-weight: bold;
}
/* Nút logout riêng */
QPushButton#btn_logout {
    background-color: transparent;
    color: #E8A0A0;
    font-size: 13px;
    text-align: left;
    padding: 12px 18px;
    border: none;
    border-top: 1px solid #2A3D5E;
    border-left: 3px solid transparent;
    border-radius: 0px;
}
QPushButton#btn_logout:hover {
    background-color: #4A1818;
    color: #FFFFFF;
    border-left: 3px solid #E8A0A0;
}
       </string>
